# WhatsApp (sem +, apenas dígitos; ex: 595981234567)
NEXT_PUBLIC_WHATSAPP_NUMBER=595000000000

# Analytics (preencher quando tiver)
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_META_PIXEL_ID=
NEXT_PUBLIC_GTM_ID=

# Fase 2 (Painel admin)
# No Railway: o plugin Postgres injeta DATABASE_URL automaticamente.
# IMPORTANTE: defina APP_DATABASE_URL apontando para o mesmo Postgres MAS
# em schema isolado, para não colidir com dados de outros projetos:
#   APP_DATABASE_URL=${{Postgres.DATABASE_URL}}?schema=status
APP_DATABASE_URL=postgresql://user:pass@host:5432/status?schema=status

# NextAuth — gere com: openssl rand -base64 32
AUTH_SECRET=troque-este-valor-em-producao
NEXTAUTH_URL=http://localhost:3000

# Admin (usado pelo seed; depois do primeiro seed você pode remover ADMIN_PASSWORD)
ADMIN_EMAIL=thiago.fregolao@gmail.com
ADMIN_PASSWORD=1571jn
